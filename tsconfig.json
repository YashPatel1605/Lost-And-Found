{
	"compilerOptions": {
		"target": "ESNext",
		"useDefineForClassFields": true,
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"allowJs": true,
		"checkJs": false,
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"isolatedModules": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"skipLibCheck": true
	},
	"include": ["src"],
	"references": [{ "path": "./tsconfig.node.json" }]
}
